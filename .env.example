# PostgreSQL
POSTGRES_PASSWORD=sua_senha_do_banco
DB_PASSWORD=sua_senha_do_banco

# Django
# Gere uma chave nova com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque_por_uma_chave_secreta_unica
DEBUG=False
# Hosts permitidos, separados por virgula (ex: app.seudominio.com.br,.seudominio.com.br)
ALLOWED_HOSTS=localhost,127.0.0.1

# Email (Resend SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_sua_chave_api_resend
DEFAULT_FROM_EMAIL=noreply@seudominio.com.br
